<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Duvidas Frequentes"
            android:textColor="@color/cesumar_blue"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:id="@+id/card_faq1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Quando acontece a Tech Week?" android:textColor="@color/cesumar_blue" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:id="@+id/txt_resp1" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="A Tech Week 2024 acontece durante a semana letiva. Confira a programacao completa na tela inicial do app." android:textColor="@color/gray_text" android:textSize="13sp" android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_faq2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Onde sera realizado o evento?" android:textColor="@color/cesumar_blue" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:id="@+id/txt_resp2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="O evento acontece na UniCesumar, em Londrina - PR. Toque em Mapa no menu para abrir o Google Maps." android:textColor="@color/gray_text" android:textSize="13sp" android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_faq3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Como me inscrevo nas atividades?" android:textColor="@color/cesumar_blue" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:id="@+id/txt_resp3" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Toque em Inscrever no menu e preencha o formulario com seu Nome, RA, Curso e Semestre." android:textColor="@color/gray_text" android:textSize="13sp" android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_faq4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="O que e o Coffee Break?" android:textColor="@color/cesumar_blue" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:id="@+id/txt_resp4" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="E um intervalo com cafe e lanches para participantes inscritos. Marque a opcao no formulario de inscricao." android:textColor="@color/gray_text" android:textSize="13sp" android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_faq5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Como confirmo presenca na palestra?" android:textColor="@color/cesumar_blue" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:id="@+id/txt_resp5" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Ao final de cada palestra, o responsavel exibe um codigo. Acesse Confirmar Presenca no menu e informe seu RA e o codigo." android:textColor="@color/gray_text" android:textSize="13sp" android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_faq6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Posso apresentar um projeto?" android:textColor="@color/cesumar_blue" android:textSize="14sp" android:textStyle="bold" />
                <TextView android:id="@+id/txt_resp6" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Sim! Acesse Projetos no menu e cadastre seu projeto com nome, RA, titulo e descricao." android:textColor="@color/gray_text" android:textSize="13sp" android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
